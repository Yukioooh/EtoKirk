# Configuration de l'application Twitch Correlation Analyzer
# Copiez ce fichier vers .env et remplissez vos vraies valeurs

# ============================================
# CREDENTIALS TWITCH (OBLIGATOIRES)
# ============================================
# Obtenez-les sur https://dev.twitch.tv/console/apps
# Créez une application Twitch et copiez l'ID et le Secret
TWITCH_CLIENT_ID=votre_client_id_ici
TWITCH_CLIENT_SECRET=votre_client_secret_ici

# ============================================
# CONFIGURATION DES STREAMERS
# ============================================
# Les deux streamers à analyser (noms d'utilisateur Twitch en minuscules)
STREAMER_1=tikyjr
STREAMER_2=etostark

# ============================================
# CONFIGURATION SERVEUR
# ============================================
# Port sur lequel l'application écoute (3001 par défaut)
PORT=3001

# Intervalle entre les vérifications de stream en secondes
# Minimum 60 pour respecter les rate limits de Twitch
POLLING_INTERVAL=60

# ============================================
# NOTES DE SÉCURITÉ
# ============================================
# - Ne partagez jamais ce fichier .env réel
# - Les credentials Twitch sont sensibles et personnels
# - La base de données SQLite reste locale sur le serveur
# - Pour le déploiement, configurez ces valeurs sur le VPS uniquement
